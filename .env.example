# Database
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# App
NODE_ENV=development
PORT=5000

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=1d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

# CORS (comma-separated origins, use * for development)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (all optional, shown with defaults)
# Login: max attempts per window
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
# OTP (email verification & password reset): max requests per window
RATE_LIMIT_OTP_WINDOW_MS=600000
RATE_LIMIT_OTP_MAX=3
# Verification request submission: max requests per window
RATE_LIMIT_VERIFICATION_WINDOW_MS=86400000
RATE_LIMIT_VERIFICATION_MAX=5
# Onboarding: max requests per window
RATE_LIMIT_ONBOARDING_WINDOW_MS=900000
RATE_LIMIT_ONBOARDING_MAX=20

# Mail Provider Configuration
# Options: "resend" (production) | "gmail" (development)
MAIL_PROVIDER=gmail

# Resend provider (production)
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=onboarding@resend.dev

# Gmail provider (development)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=smart-nub-campus

# Upload limits (optional)
MAX_UPLOAD_SIZE_MB=5

# Seed admin (used in prisma/seed)
SEED_ADMIN_EMAIL=admin@nub.ac.bd
SEED_ADMIN_PASSWORD=admin12345678
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_DESIGNATION=System Admin
