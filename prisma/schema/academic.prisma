model Course {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  department  Department
  semester    Int?
  description String?

  resources   Resource[]
  discussions Discussion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@index([code])
  @@map("course")
}
