model UserProfile {
    id String @id @default(uuid())
    userId String @unique
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    bio String?
    coverImage String?
    githubUrl String?
    linkedinUrl String?
    portfolioUrl String?
    websiteUrl String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("user_profiles")
}