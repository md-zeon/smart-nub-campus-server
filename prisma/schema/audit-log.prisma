model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Restrict)
  action      String
  targetType  String
  targetId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
