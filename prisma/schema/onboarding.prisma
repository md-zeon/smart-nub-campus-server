model VerificationRequest {
  id String @id @default(uuid())

  // Personal Information
  name                String
  email               String   @unique
  dateOfBirth         DateTime
  studentId           String   @unique
  idCardImage         String // Cloudinary URL
  idCardImagePublicId String? // Cloudinary public ID for cleanup

  // Verification
  status VerificationStatus @default(PENDING)
  note   String?

  // Review audit
  reviewedById String?
  reviewedBy   User?     @relation("VerificationReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  // Relation
  onboardingStep OnboardingStep?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewedById])
  @@map("verification_requests")
}

model OnboardingStep {
  id String @id @default(uuid())

  verificationRequestId String @unique

  verificationRequest VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)
  step                OnboardingStepValue @default(VERIFICATION_FORM)

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_steps")
}
